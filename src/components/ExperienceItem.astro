---
interface Props {
    title: string;
    date: string;
    description: string[];
}

const { title, description, date } = Astro.props as Props;
---

<div
    class="text-left rounded-3xl
    border
    border-white/10
    bg-white/5
    backdrop-blur-md
    p-6"
>
    <time
        class="inline-block mb-3 px-3 py-1 text-xs rounded-full border border-white/10 bg-white/5 text-sky-300"
    >
        {date}s
    </time>

    <h3 class="text-xl font-semibold text-white mb-4">
        {title}
    </h3>

    <ul class="space-y-3">
        {
            description.map((item) => (
                <li class="flex gap-3 text-gray-300 ">
                    <span class="mt-2 h-2 w-2 rounded-full bg-blue-500 shrink-0"></span>
                    <span>{item}</span>
                </li>
            ))
        }
    </ul>
</div>
