---
const { title, description, date } = Astro.props;
---

<span
    class="absolute flex items-center justify-center w-6 h-6 bg-yellow-500/20 rounded-full -start-3 ring-8 ring-buffer"
>
    <svg
        class="w-3 h-3 text-yellow-400"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
    >
        <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"          text: "Download ZIP",
            stroke-width="2"
            d="M12 6v6l4 2"
        />
    </svg>
</span>

<time
    class="inline-block mb-2 px-3 py-1 text-xs rounded-full border border-white/10 bg-white/5 text-sky200/80"
>
    {date}
</time>

<h3 class="text-xl font-semibold text-white mb-4">
    {title}
</h3>

<ul class="space-y-3">
  {Array.isArray(description) &&
    description.map((item) => (
      <li class="flex gap-3 text-gray-300">
        <span class="mt-2 h-2 w-2 rounded-full bg-yellow-400 shrink-0"></span>
        <span>{item}</span>
      </li>
    ))
  }
</ul>
