---
import CodeIcon from "../components/Code.astro";
const PROJECTS = [
    {
        title: "Sistema de Control de Stock",
        description:
            "Sistema web para la gestión de inventario, ventas y facturación. Permite administrar productos, clientes y controlar el stock en tiempo real mediante una interfaz intuitiva.",
        link: "https://sistema-stock.infinityfreeapp.com/",
        github: "https://github.com/Abelr09/sistema-stock",
        image: "/projects-img/sistema.webp",
        tags: ["PHP", "Bootstrap", "JavaScript", "MySQL", "HTML", "CSS"],
    },
    {
        title: "Batalla de Mbororé",
        description:
            "Sitio web desarrollado en equipo para difundir la historia de la Batalla de Mbororé mediante una experiencia interactiva, moderna y totalmente responsive.",
        link: "https://batalla-mborore.vercel.app",
        github: "https://github.com/Abelr09/batalla-mborore",
        image: "/projects-img/mborore.webp",
        tags: ["Astro", "Tailwind CSS", "JavaScript", "HTML", "CSS"],
    },
    {
        title: "Clasificador Inteligente de Leads",
        description:
            "Automatización inteligente de leads con n8n e IA. Clasifica intenciones, analiza sentimientos y gestiona respuestas multicanal (Slack, Email, Sheets).",
        link: "#",
        github: "https://github.com/Abelr09/Clasificador-Inteligente-de-Leads",
        image: "/projects-img/n8n.webp",
        tags: ["n8n", "Open API", "AI", "Docker", "Automation"],
    },
    {
        title: "Price Monitor RPA",
        description:
            "Bot de Rocketbot que extrae productos de Nissei. Extrae precios, url, nombre de los productos y los envia por correo electrónico.",
        link: "#",
        github: "https://github.com/Abelr09/Price_Monitor_RPA",
        image: "/projects-img/price_monitor_rpa.mp4",
        tags: ["Rocketbot Studio", "Python", "RPA"],
    },
    {
        title: "Bot extractor de información web",
        description:
            "Herramienta desarrollada con Python y Selenium para extraer información de sitios web, obteniendo títulos, autores, etiquetas y estadísticas de forma automática.",
        link: "#",
        github: "https://github.com/Abelr09/WebScraping",
        image: "/projects-img/obtener_datos.webp",
        tags: ["Selenium", "Python", "Automation"],
    },
    {
        title: "Folder Cleaner Bot",
        description:
            "Utilidad desarrollada en Python que conserva únicamente los cinco archivos más recientes de una carpeta y elimina el resto para mantener el sistema organizado.",
        link: "#",
        github: "https://github.com/Abelr09/Folder_cleaner_bot",
        image: "/projects-img/foldercleaner.webp",
        tags: ["Python", "PathLib", "Automation"],
    },
];
---

<section>
    <div class="mb-16 text-center">
        <h2
            class="flex items-center justify-center gap-3
            text-3xl md:text-4xl
            font-bold
            text-white"
        >
            <CodeIcon class="w-8 h-8 text-blue-400" />
            Proyectos
        </h2>

        <div
            class="mx-auto
            mt-4
            h-1
            w-24
            rounded-full
            bg-blue-500"
        >
        </div>

        <p
            class="mt-6
            max-w-2xl
            mx-auto
            text-gray-400"
        >
            Algunos proyectos personales y profesionales enfocados en desarrollo
            web, automatización y soluciones empresariales.
        </p>
    </div>

   <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    {
        PROJECTS.map(
            ({ title, description, image, tags, link, github }) => (
                <article
                    class="
                    group
                    flex
                    flex-col
                    rounded-2xl
                    border
                    border-white/10
                    bg-white/5
                    backdrop-blur-md
                    overflow-hidden
                    transition-all
                    duration-300
                    hover:-translate-y-2
                    hover:border-blue-500/40
                    hover:shadow-[0_0_30px_rgba(59,130,246,.18)]
                "
                >
                    <!-- Imagen o Video -->
                    <div class="p-5 pb-0">
                        <div class="overflow-hidden rounded-xl bg-black/30">
                            {
                                image.endsWith(".mp4") ? (
                                    <video
                                        autoplay
                                        muted
                                        loop
                                        playsinline
                                        class="h-56 w-full object-cover transition duration-500 group-hover:scale-105"
                                    >
                                        <source src={image} type="video/mp4" />
                                    </video>
                                ) : (
                                    <img
                                        src={image}
                                        alt={title}
                                        class="h-56 w-full object-cover transition duration-500 group-hover:scale-105"
                                    />
                                )
                            }
                        </div>
                    </div>

                    <!-- Contenido -->
                    <div class="flex flex-col flex-1 p-5">

                        <h3 class="text-2xl font-bold text-white">
                            {title}
                        </h3>

                        <p class="mt-3 text-gray-400 leading-7 flex-1">
                            {description}
                        </p>

                        <!-- Tags -->

                        <div class="mt-5 flex flex-wrap gap-2">
                            {
                                tags.map((tag) => (
                                    <span
                                        class="
                                        rounded-full
                                        bg-blue-500/10
                                        px-3
                                        py-1
                                        text-xs
                                        text-blue-300
                                    "
                                    >
                                        {tag}
                                    </span>
                                ))
                            }
                        </div>

                        <!-- Botones -->

                        <div class="mt-6 flex gap-3">

                            {
                                link !== "#" && (
                                    <a
                                        href={link}
                                        target="_blank"
                                        class="
                                        flex-1
                                        rounded-lg
                                        border
                                        border-blue-500
                                        py-2.5
                                        text-center
                                        text-sm
                                        font-semibold
                                        text-blue-400
                                        transition-all
                                        hover:bg-blue-500
                                        hover:text-white
                                    "
                                    >
                                        Ver Demo
                                    </a>
                                )
                            }

                            {
                                github !== "#" && (
                                    <a
                                        href={github}
                                        target="_blank"
                                        class={`
                                            rounded-lg
                                            py-2.5
                                            text-sm
                                            font-semibold
                                            text-center
                                            transition-all
                                            hover:scale-[1.03]
                                            bg-gradient-to-r
                                            from-blue-600
                                            to-purple-600
                                            text-white
                                            ${
                                                link !== "#"
                                                    ? "flex-1"
                                                    : "w-full"
                                            }
                                        `}
                                    >
                                        GitHub
                                    </a>
                                )
                            }

                        </div>

                    </div>
                </article>
            ),
        )
    }
</div>