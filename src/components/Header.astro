---
import photo from "../assets/photo.jpeg";
---

<header
  class="fixed
		top-4
		left-1/2
		transform -translate-x-1/2
        z-50
        w-[95%]
        max-w-6xl"
>
  <div
    class="rounded-2xl
			border
			border-white/10
			bg-white/5
			backdrop-blur-xl
			shadow-[0_8px_32px_rgba(0,0,0,.4)]
			px-4
            py-3"
  >
    <div class="md:hidden flex items-center justify-between">
      <img
        src={photo.src}
        alt="Abel Amarilla"
        width={120}
        height={120}
        class="w-10
					h-10
					object-cover
					rounded-full
					border-2
					border-white/20
					shadow-[0_0_25px_rgba(59,130,246,.4)]
                    ring-2
                    ring-blue-500/30"
      />
      <button
        id="menu-btn"
        class="text-white
                text-3xl
                transition-all
                duration-300"
      >
        <span id="menu-open">☰</span>
        <span id="menu-close" class="hidden">✕</span>
      </button>
    </div>

    <div class="hidden md:flex items-center gap-8">
      <img
        src={photo.src}
        alt="Abel Amarilla"
        class="w-10
                h-10
                object-cover
                rounded-full
                border-2
                border-white/20
                shadow-[0_0_25px_rgba(59,130,246,.4)]
                ring-2
                ring-blue-500/30"
      />

      <nav class="flex
					gap-8
					text-gray-300">
        <a href="#top" class="nav-link">Inicio</a>
        <a href="#sobre-mi" class="nav-link">Sobre mí</a>
        <a href="#experiencia" class="nav-link">Experiencia</a>
        <a href="#proyectos" class="nav-link">Proyectos</a>
        <a href="#contacto" class="nav-link">Contacto</a>
      </nav>
    </div>
  </div>
</header>
<div
  id="overlay"
  class="fixed
                inset-0
                bg-black/50
                backdrop-blur-sm
                hidden
                z-40"
>
</div>

<div
  id="mobile-menu"
  class="fixed top-0 -right-full h-screen w-[70%] bg-black/90 backdrop-blur-xl border-l border-white/10 z-50 transition-all duration-300"
>
  <div class="p-8">
    <nav class="flex flex-col gap-8 text-xl">
      <a href="#top" class="nav-link">Inicio</a>
      <a href="#sobre-mi" class="nav-link">Sobre mí</a>
      <a href="#experiencia" class="nav-link">Experiencia</a>
      <a href="#proyectos" class="nav-link">Proyectos</a>
      <a href="#contacto" class="nav-link">Contacto</a>
    </nav>
  </div>
</div>

<style>
  .nav-link {
    position: relative;
    transition: all 0.3s ease;
  }
  .nav-link:hover {
    color: white;
    text-shadow:
      0 0 8px rgba(59, 130, 246, 0.8),
      0 0 16px rgba(59, 130, 246, 0.6),
      0 0 24px rgba(59, 130, 246, 0.4);
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #3b82fe, #8b5cf6, #ec4899);
    transition: 0.3s;
  }
  .nav-link:hover::after {
    width: 100%;
  }
</style>
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById("menu-btn");
    const menu = document.getElementById("mobile-menu");
    const overlay = document.getElementById("overlay");
    const links = document.querySelectorAll("#mobile-menu a");
    const openIcon = document.getElementById("menu-open");
    const closeIcon = document.getElementById("menu-close");

    function closeMenu() {
      menu?.classList.add("-right-full");
      menu?.classList.remove("right-0");
      overlay?.classList.add("hidden");
      openIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    }

    btn?.addEventListener("click", () => {
      menu?.classList.toggle("-right-full");
      menu?.classList.toggle("right-0");

      overlay?.classList.toggle("hidden");
      openIcon?.classList.toggle("hidden");
      closeIcon?.classList.toggle("hidden");
    });

    overlay?.addEventListener("click", closeMenu);

    links.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    });
    overlay?.addEventListener("click", closeMenu);
  });
</script>
