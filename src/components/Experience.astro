---
import ExperienceItem from "./ExperienceItem.astro";
import SuitcaseIcon from "../icons/Suitcase.astro";

const EXPERIENCE = [
    {
        date: "Octubre 2025 - Actualidad",
        title: "Banco Itaú (InQuality S.A.) |  Desarrollador Full Stack",
        description: [
            "Automatización de procesos con Automate (emails y gestión de archivos)",
            "Desarrollo de macros VBA para sistemas legacy en Excel",
            "Consultas y gestión de datos con SQL Server",
            "Web scraping",
            "Soporte técnico a usuarios",
            "Reducción de tiempos operativos mediante automatización",
            "Documentación técnica y manuales de usuario",
        ],
        badge: "Latest",
        badgeColor: "bg-brand-softer border-brand-subtl5 se text-fg-brand-strong",
        link: {
            href: "#",
            icon: {
                width: 4,
                height: 4,
                marginRight: 1.5,
                marginLeft: -0.5,
            },
        },
    },
    {
        date: "Enero 2024 - Octubre 2025",
        title: "Analista de automatización RPA",
        description: [
            "Desarrollo de bots con Rocketbot para procesos financieros y conciliaciones bancarias (extracción, matching y reportes), reduciendo errores manuales",
            "Automatización web con Python (Selenium) e integración con PostgreSQL y Oracle",
            "Automatización de procesos de negocio (IVA, RG90, correos con n8n)",
            "Relevamiento de procesos, dimensionamiento de soluciones y desarrollo de POC",
            "Diseño de diagramas de flujo y participación en reuniones con clientes",
            "Documentación técnica y manuales de usuario",
        ],
    },
    {
        date: "Octubre 2023 - Enero 2024",
        title: "InQuality S.A.| Web Developer (WordPress)",
        description: [
            "Mantenimiento y mejora de sitio web de la empresa (WordPress)",
            "Personalización con HTML, CSS, JS y PHP",
            "Optimización de rendimiento y SEO",
            "Implementación de medidas de seguridad y actualizaciones",
            "Colaboración con equipo de marketing para contenido y diseño",
        ],
    },
];
---
<div class="mb-16 text-center">
    <h2
        class="flex items-center justify-center gap-3
        text-3xl md:text-4xl
        font-bold
        text-white"
    >
        <SuitcaseIcon class="w-8 h-8 text-blue-400" />
        Experiencia
    </h2>

    <div
        class="mx-auto mt-4 h-1 w-24 rounded-full bg-blue-500"
    ></div>

    <p class="mt-6 text-gray-400 max-w-2xl mx-auto">
        Mi experiencia profesional desarrollando soluciones web,
        automatizaciones y herramientas empresariales.
    </p>
</div>

<ol class="relative">

    <!-- Línea central desktop -->
    <div
        class="hidden md:block
        absolute
        left-1/2
        top-0
        -translate-x-1/2
        w-[2px]
        h-full
        bg-white/10"
    />

    <!-- Línea mobile -->
    <div
        class="md:hidden
        absolute
        left-3
        top-0
        w-[2px]
        h-full
        bg-white/10"
    />

    {
        EXPERIENCE.map((experience, index) => (
            <li class="relative mb-20">

                <!-- Desktop -->
                <div class="hidden md:flex items-start">

                    <div class={`w-1/2 ${index % 2 === 0 ? "pr-16" : ""}`}>
                        {index % 2 === 0 && (
                            <ExperienceItem {...experience} />
                        )}
                    </div>

                    <!-- Nodo central -->
                    <div
                        class="absolute
                        left-1/2
                        top-4
                        -translate-x-1/2
                        w-10
                        h-10
                        rounded-full
                        bg-blue-500/20
                        border
                        border-blue-400/40
                        backdrop-blur-md
                        flex
                        items-center
                        justify-center"
                    >
                        <svg
                            class="w-4 h-4 text-blue-400"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke="currentColor"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 6v6l4 2"
                            />
                        </svg>
                    </div>

                    <div class={`w-1/2 ${index % 2 !== 0 ? "pl-16" : ""}`}>
                        {index % 2 !== 0 && (
                            <ExperienceItem {...experience} />
                        )}
                    </div>
                </div>
                <!-- Mobile -->
                <div class="md:hidden relative pl-10">

    <div
        class="absolute
        left-0
        top-4
        w-6
        h-6
        rounded-full
        bg-blue-500/20
        border
        border-blue-400/40
        backdrop-blur-sm
        flex
        items-center
        justify-center"
    >
        <svg
            class="w-3 h-3 text-blue-400"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
        >
            <path
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 6v6l4 2"
            />
        </svg>
    </div>

    <ExperienceItem {...experience} />

</div>

            </li>
        ))
    }

</ol>