---
import SuitcaseIcon from "../icons/UserIcon.astro";
const technologies = [
    { name: "Python", icon: "../../src/assets/python.png" },
    { name: "JavaScript", icon: "../../src/assets/js.jpg" },
    { name: "Astro", icon: "../../src/assets/astro.svg" },
    { name: "Tailwind", icon: "../../src/assets/tw.png" },
    { name: "PHP", icon: "../../src/assets/php.png" },
    { name: "Oracle", icon: "../../src/assets/oracle.png" },
    { name: "Rocketbot", icon: "../../src/assets/rocketbot.png" },
    { name: "n8n", icon: "../../src/assets/n8n.png" },
];
---
<section id="about" class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="mb-14 text-center">
        <h2
            class="flex items-center justify-center gap-3
            text-3xl md:text-4xl
            font-bold
            text-white"
        >
            <SuitcaseIcon class="w-10 h-10 text-blue-400" />
            Sobre mí
        </h2>
        
        <div class="mx-auto mt-4 h-1 w-24 rounded-full bg-blue-500"></div>
    </div>

    <div class="text-center max-w-3xl mx-auto space-y-6">
        <h3 class="text-2xl md:text-3xl font-bold text-white">
            Desarrollador Full Stack & RPA
        </h3>

        <p class="mb-4 text-base md:text-lg text-gray-300 leading-relaxed">
            Soy Abel Amarilla, desarrollador enfocado en la creación de
            aplicaciones web modernas y automatización de procesos.
        </p>

        <p class="mb-4 text-base md:text-lg text-gray-300 leading-relaxed">
            Tengo experiencia desarrollando soluciones con Python, PHP,
            JavaScript y herramientas de RPA como Rocketbot y Selenium.
        </p>

        <p class="mb-4 text-base md:text-lg text-gray-300 leading-relaxed">
            Me apasiona resolver problemas, optimizar procesos y crear productos
            digitales útiles para personas y empresas.
        </p>
    </div>

    <div class="w-full overflow-hidden mt-16">
        <div class="carousel-track">
            {
                [...technologies, ...technologies].map((tech) => (
                    <div class="tech-card flex-shrink-0">
                        <img src={tech.icon} alt={tech.name} />
                        <span>{tech.name}</span>
                    </div>
                ))
            }
        </div>
    </div>
</section>

<style>
    .carousel-track {
        display: flex;
        width: max-content;
        gap: 1.5rem;
        animation: scroll 25s linear infinite;
    }

    .tech-card {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        padding: 16px 28px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        min-width: 220px;
        transition: 0.3s;
    }

    .tech-card:hover {
        border-color: rgba(59, 130, 246, 0.5);

        box-shadow: 0 0 25px rgba(59, 130, 246, 0.25);
    }

    .tech-card img {
        width: 20px;
        height: 20px;
        object-fit: contain;
    }

    .tech-card {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        padding: 8px 14px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(15px);
        min-width: 110px;
        transition: 0.3s;
    }
    .tech-card:hover {
        border-color: rgba(59, 130, 246, 0.5);

        box-shadow: 0 0 25px rgba(59, 130, 246, 0.25);
    }

    .tech-card span {
        color: white;
        font-weight: 600;
        font-size: 1rem;
    }
    @media (min-width: 768px) {
        .tech-card {
            min-width: 170px;
            padding: 20px 32px;
        }
        .tech-card img {
            width: 32px;
            height: 32px;
        }
        .tech-card span {
            font-size: 1.1rem;
        }
    }

    @keyframes scroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }
</style>
