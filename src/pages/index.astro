---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import SectionContainer from "../components/SectionContainer.astro";
import LinkedInIcon from "../icons/LinkedIn.astro";
import GitHubIcon from "../icons/GitHub.astro";
import InstagramIcon from "../icons/Instagram.astro";
import GmailIcon from "../icons/Gmail.astro";
import Experience from "../components/Experience.astro";
import SuitcaseIcon from "../icons/Suitcase.astro";
import CodeIcon from "../components/Code.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import About from "../components/About.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout
	title="Portfolio de Abel - desarrollador Full Stack, Programador Web y RPA Developer"
	description="Bienvenido a mi portfolio de desarrollo web, donde encontrarás proyectos innovadores y soluciones creativas. Soy un desarrollador Full Stack apasionado por la tecnología y la programación, con experiencia en una amplia gama de tecnologías y herramientas. Explora mis proyectos destacados, desde aplicaciones web hasta soluciones de automatización, y descubre cómo puedo contribuir a tu próximo proyecto. ¡Gracias por visitar mi portfolio!"
>
	<main class="flex-1 w-full xl:w-[1120px] mx-auto px-5">
		<SectionContainer class="py-44 pb-32">
			<h1
				class="text-white text-3xl md:text-4xl lg:text-5xl font-bold flex flex-row gap-x-4 pb-6 lg:pb-10"
			>
				Hey, soy Abel!
				<a
					href="https://linkedin.com/in/abelr09"
					target="_blank"
					rel="noopener"
					class="flex justify-center items-center"
				>
					<Badge>Disponible para trabajar</Badge>
				</a>
			</h1>
			<h2 class="text-xl lg:text-2xl text-wrap max-w-[700px]"></h2>

			<h2>
				<span class="text-yellow-200/90">+1 año de experiencia</span>. <span
					class="text-white">Desarrollador Full Stack.</span
				>
				<span class="text-red-200/90"
					>De San Ignacio Misiones, Paraguay.</span
				><br />
				Estoy emocionado por la oportunidad de contribuir a proyectos innovadores
				y seguir creciendo como desarrollador.
			</h2>
			<ul
				class="flex flex-wrap justify-center md:justify-start gap-4 mt-10"
			>
				<li>
					<a
						href="https://linkedin.com/in/abelr09"
						target="_blank"
						rel="noopener"
						class="group flex items-center gap-3 px-5 py-3 rounded-full border border-white/30 bg-white/5 backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:-translate-y-1 hover:border-blue-500 hover:bg-blue-500/10 hover:shadow-[0_0_25px_rgba(59,130,246,0.8)]"
					>
						<LinkedInIcon
							class="w-6 h-6 fill-current text-blue-500 transition-transform duration-300 group-hover:rotate-6"
						/>
						<span class="text-white font-medium">LinkedIn</span>
					</a>
				</li>

				<li>
					<a
						href="https://github.com/abelr09"
						target="_blank"
						rel="noopener"
						class="group flex items-center gap-3 px-5 py-3 rounded-full border border-white/30 bg-white/5 backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:-translate-y-1 hover:border-gray-400 hover:bg-gray-500/10 hover:shadow-[0_0_25px_rgba(156,163,175,0.8)]"
					>
						<GitHubIcon
							class="w-6 h-6 fill-current text-white transition-transform duration-300 group-hover:rotate-6"
						/>
						<span class="text-white font-medium">GitHub</span>
					</a>
				</li>

				<li>
					<a
						href="https://instagram.com/abel_amarilla9"
						target="_blank"
						rel="noopener"
						class="group flex items-center gap-3 px-5 py-3 rounded-full border border-white/30 bg-white/5 backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:-translate-y-1 hover:border-pink-500 hover:bg-pink-500/10 hover:shadow-[0_0_25px_rgba(236,72,153,0.8)]"
					>
						<InstagramIcon
							class="w-6 h-6 fill-current text-pink-500 transition-transform duration-300 group-hover:rotate-6"
						/>
						<span class="text-white font-medium">Instagram</span>
					</a>
				</li>

				<li>
					<a
						href="mailto:abelamarilla51777@gmail.com"
						target="_blank"
						rel="noopener"
						class="group flex items-center gap-3 px-5 py-3 rounded-full border border-white/30 bg-white/5 backdrop-blur-sm transition-all duration-300 hover:scale-110 hover:-translate-y-1 hover:border-green-500 hover:bg-green-500/10 hover:shadow-[0_0_25px_rgba(72,187,120,0.8)]"
					>
						<GmailIcon
							class="w-6 h-6 fill-current text-white transition-transform duration-300 group-hover:rotate-6"
						/>
						<span class="text-white font-medium">Gmail</span>
					</a>
				</li>
			</ul>
		</SectionContainer>

		<SectionContainer id="sobre-mi">
			<About />
		</SectionContainer>

		<SectionContainer id="experiencia">
			<h2 class="text-2xl font-semibold mb-6 flex gap-x-3 items-center">
				<SuitcaseIcon class="relative w-7 h-7 text-yellow-300" />
				Experiencia Laboral
			</h2>

			<Experience />
		</SectionContainer>

		<SectionContainer id="experiencia">
			<h2 class="text-2xl font-semibold mb-6 flex gap-x-3 items-center">
				<SuitcaseIcon class="relative w-7 h-7 text-yellow-300" />
				Experiencia Laboral
			</h2>

			<Experience />
		</SectionContainer>

		<SectionContainer id="proyectos">
			<h2 class="text-2xl font-semibold mb-6 flex gap-x-3 items-center">
				<CodeIcon class="relative w-7 h-7 text-yellow-300" />
				Proyectos
			</h2>

			<Projects />
		</SectionContainer>

		<SectionContainer id="contacto">
			<Contact />
		</SectionContainer>
	</main>
</Layout>
